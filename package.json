{
  "name": "@plutopay/node",
  "version": "0.1.0",
  "description": "PlutoPay Node.js SDK — accept card, ACH, terminal, and hosted-checkout payments.",
  "license": "MIT",
  "author": "PlutoPay",
  "homepage": "https://docs.plutopayus.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PlutoPayUS/plutopay-node.git"
  },
  "bugs": {
    "url": "https://github.com/PlutoPayUS/plutopay-node/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "node --test test/*.test.mjs",
    "generate": "bash scripts/generate.sh",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "plutopay",
    "payments",
    "api",
    "sdk",
    "stripe-alternative",
    "checkout",
    "ach"
  ],
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
